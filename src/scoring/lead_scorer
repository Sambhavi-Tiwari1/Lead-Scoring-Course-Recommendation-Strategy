        Predict conversion probability for a lead
        """
        # Convert customer data to feature vector
        features = self._prepare_single_customer(customer_data)
        
        # Get probability
        probability = self.model.predict_proba(features)[0, 1]
        
        # Get score (0-100 scale)
        score = probability * 100
        
        # Determine segment based on score
        if score > 80:
            segment = "High-Value"
        elif score > 60:
            segment = "Engaged"
        elif score > 40:
            segment = "Casual"
        else:
            segment = "Low-Engagement"
        
        return {
            'customer_id': customer_data.get('customer_id', 'unknown'),
            'score': round(score, 1),
            'probability': round(probability, 4),
            'segment': segment,
            'conversion_risk': 'High' if probability > 0.7 else 'Medium' if probability > 0.4 else 'Low',
            'recommendations': self._get_recommendations(segment)
        }
    
