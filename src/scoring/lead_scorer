    def _get_recommendations(self, segment: str) -> List[str]:
        """Get recommendations based on segment"""
        recommendations = {
            "High-Value": [
                "Send premium course recommendations",
                "Offer exclusive discounts on advanced courses",
                "Schedule personalized consultation"
            ],
            "Engaged": [
                "Recommend relevant courses based on history",
                "Send targeted content related to interests",
                "Offer bundle packages"
            ],
            "Casual": [
                "Send engaging content and testimonials",
                "Provide free introductory resources",
                "Offer limited-time promotions"
            ],
            "Low-Engagement": [
                "Re-engage with personalized email campaigns",
                "Offer free sample courses",
                "Survey to understand interests and barriers"
            ]
        }
        return recommendations.get(segment, ["Continue engagement efforts"])
    
    def save_model(self, path: str = "models/lead_scorer.joblib"):
        """Save trained model"""
        joblib.dump({
            'model': self.model,
            'scaler': self.scaler,
            'label_encoders': self.label_encoders,
            'feature_importance': self.feature_importance,
            'model_type': self.model_type
        }, path)
        logger.info(f"Model saved to {path}")
    
    def load_model(self, path: str = "models/lead_scorer.joblib"):
        """Load trained model"""
        data = joblib.load(path)
        self.model = data['model']
        self.scaler = data['scaler']
        self.label_encoders = data.get('label_encoders', {})
        self.feature_importance = data.get('feature_importance')
        self.model_type = data.get('model_type', 'xgboost')
        logger.info(f"Model loaded from {path}")
